# Copy to .env on the VPS and fill in. Never commit .env.
GCS_ENABLED=true
GCS_BUCKET=vol2vol-bronze-prod

# GCP service account key is mounted at this path (see docker-compose volumes).
# Place the JSON at ./secrets/gcp-key.json — do not commit it.
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/secrets/gcp-key.json
