# Copy to .env on the VM and fill in. Never commit .env.
GCS_ENABLED=true
GCS_BUCKET=oi-intraday-bucket

# GCP service account key is mounted at this path (see docker-compose volumes).
# Place the JSON at ./secrets/gcp-key.json — do not commit it.
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/secrets/gcp-key.json

# Airflow web UI admin password (UI is loopback-only, reached via SSH tunnel).
AIRFLOW_ADMIN_PASSWORD=change-me
